# ============================================
# 用法
# ============================================
# 开发：cp .env.example .env，保持下面默认值即可
# 生产：cp .env.example .env，至少修改以下项：
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://真实域名
#   APP_DOMAIN=真实域名
#   DB_PASSWORD=强随机密码
#   REDIS_PASSWORD=强随机密码
#   CADDY_EMAIL=运维邮箱（Let's Encrypt 注册）
#   APP_KEY=（运行 php artisan key:generate 生成）

# ============================================
# Docker 编排（不是 Laravel 本身的变量）
# ============================================
COMPOSE_PROJECT_NAME=forge-cms
PHP_VERSION=8.5.5
FRANKENPHP_VERSION=1.12.2

# ============================================
# 开发端口（避开 80/443）
# ============================================
APP_PORT=8080
# APP_HTTPS_PORT=8443    # dev 默认关 HTTPS,仅当你改 Caddyfile.dev 启用 HTTPS 时才用
POSTGRES_PORT=5432
VALKEY_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
MEILISEARCH_PORT=7700

# ============================================
# 域名与 ACME
# ============================================
SERVER_NAME=forge-cms.localhost
APP_DOMAIN=forge-cms.example.com
CADDY_EMAIL=admin@example.com

# ============================================
# Laravel 应用
# ============================================
APP_NAME=ForgeCMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://forge-cms.localhost:8443
APP_TIMEZONE=Asia/Shanghai

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ============================================
# 日志
# ============================================
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# 数据库（PostgreSQL）
# ============================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=forge_cms
DB_USERNAME=forge_cms
DB_PASSWORD=secret

# ============================================
# 会话（Redis/Valkey）
# ============================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================
# 缓存 / 队列 / 广播 / 存储
# ============================================
CACHE_STORE=redis
# CACHE_PREFIX=
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# ============================================
# Redis / Valkey
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=null

# ============================================
# Mail（开发 Mailpit / 生产 SMTP）
# ============================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@forge-cms.localhost"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# 对象存储（S3/R2，生产可选）
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# 搜索（Meilisearch via Scout）
# ============================================
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

# ============================================
# Octane（FrankenPHP worker 模式）
# ============================================
OCTANE_SERVER=frankenphp

# ============================================
# Inertia SSR（生产启用，开发可关）
# ============================================
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714

# ============================================
# Reverb（WebSocket 广播）
# ============================================
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ============================================
# Vite
# ============================================
VITE_APP_NAME="${APP_NAME}"

# ============================================
# Xdebug（开发调试，默认关闭）
# ============================================
XDEBUG_MODE=off
